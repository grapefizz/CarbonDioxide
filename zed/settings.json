// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "which_key": {
    "delay_ms": 750,
    "enabled": true
  },
  "buffer_font_family": "Lilex Nerd Font Mono",
  "cli_default_open_behavior": "existing_window",
  "terminal": {
    "font_family": ".ZedMono",
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_status_icon": false,
  },
  "status_bar": {
    "show_active_file": false,
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": true,
      "effort": "high",
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Symbols Icon Theme",
    "dark": "Symbols Icon Theme",
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Oxocarbon Dark (Variant I)",
  },

  "vim_mode": true,
}
